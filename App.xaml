<Application x:Class="ShigosagNexusERP.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ShigosagNexusERP.ViewModels"
             xmlns:v="clr-namespace:ShigosagNexusERP.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/TextStyles.xaml"/>
                <ResourceDictionary Source="Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 1. VECTOR ICON LIBRARY (High-Performance SVG Path Data) -->
            <Geometry x:Key="IconDashboard">M13,3V9H21V3H13M13,21H21V11H13V21M3,21H11V15H3V21M3,13H11V3H3V13Z</Geometry>
            <Geometry x:Key="IconInventory">M20,18H4V4H20M20,2H4A2,2 0 0,0 2,4V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V4A2,2 0 0,0 20,2M18,17H6V15H18M18,13H6V11H18M18,9H6V7H18Z</Geometry>
            <Geometry x:Key="IconSales">M16,11.78L20.24,4.45L21.97,5.45L16.74,14.5L10.23,10.75L5.46,19H22V21H2V3H4V17.54L9.5,8L16,11.78Z</Geometry>
            <Geometry x:Key="IconCRM">M16,13C15.71,13 15.38,13 15.03,13.05C16.19,13.89 17,15 17,16.5V19H23V16.5C23,14.17 18.33,13 16,13M8,13C5.67,13 1,14.17 1,16.5V19H15V16.5C15,15 14.19,13.89 13.03,13.05C12.68,13 12.35,13 12,13H8M8,7A3,3 0 0,0 5,10A3,3 0 0,0 8,13A3,3 0 0,0 11,10A3,3 0 0,0 8,7M16,7A3,3 0 0,0 13,10A3,3 0 0,0 16,13A3,3 0 0,0 19,10A3,3 0 0,0 16,7Z</Geometry>
            <Geometry x:Key="IconHR">M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z</Geometry>

            <!-- 2. STICKY NAV BUTTON STYLE (Updates selected state automatically) -->
            <Style x:Key="NavButtonStyle" TargetType="RadioButton">
                <Setter Property="Height" Value="50"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" Margin="8,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Selection Bar (Rose Pink) -->
                                    <Border x:Name="Indicator" Grid.Column="0" Background="{StaticResource PrimaryBrush}" 
                                            CornerRadius="2" Visibility="Collapsed" Margin="0,12"/>
                                    <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="15,0"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#25FF1493"/>
                                    <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 3. MODERN DATAGRID STYLE (Modernizes all tables) -->
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RowBackground" Value="#1A1A1A"/>
                <Setter Property="AlternatingRowBackground" Value="#222222"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="RowHeight" Value="50"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#111111"/>
                <Setter Property="Foreground" Value="#888888"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush" Value="#333333"/>
            </Style>

            <!-- To center the text inside the cells -->
            <Style TargetType="DataGridCell">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                               <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 4. SEMANTIC STATUS STYLE (Color-coded triggers) -->
            <Style x:Key="StatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold"/>
                <Style.Triggers>
                    <Trigger Property="Text" Value="Active"><Setter Property="Foreground" Value="LimeGreen"/></Trigger>
                    <Trigger Property="Text" Value="Completed"><Setter Property="Foreground" Value="LimeGreen"/></Trigger>
                    <Trigger Property="Text" Value="On Leave"><Setter Property="Foreground" Value="OrangeRed"/></Trigger>
                    <Trigger Property="Text" Value="Pending"><Setter Property="Foreground" Value="Orange"/></Trigger>
                    <Trigger Property="Text" Value="Processing"><Setter Property="Foreground" Value="DeepSkyBlue"/></Trigger>
                </Style.Triggers>
            </Style>

            <!-- 5. NAVIGATION MAPPINGS -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><v:DashboardView/></DataTemplate>
            <DataTemplate DataType="{x:Type vm:InventoryViewModel}"><v:InventoryView/></DataTemplate>
            <DataTemplate DataType="{x:Type vm:SalesViewModel}">
                <StackPanel Margin="20">
                    <TextBlock Text="Sales Intelligence" FontSize="26" FontWeight="Black" Foreground="White" Margin="0,0,0,25"/>
                    <DataGrid ItemsSource="{Binding Orders}" AutoGenerateColumns="False" Height="550">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="DATE" Binding="{Binding OrderDate, StringFormat=d}" Width="150"/>
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalAmount, StringFormat=C}" Width="150"/>
                            <DataGridTemplateColumn Header="STATUS" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextStyle}" Margin="10,0"/></DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </DataTemplate>

            <!-- 6. CRM MODULE -->
            <DataTemplate DataType="{x:Type vm:CRMViewModel}">
                <StackPanel Margin="20">
                    <TextBlock Text="CRM / Clients" FontSize="26" FontWeight="Black" Foreground="White" Margin="0,0,0,25"/>
                    <DataGrid ItemsSource="{Binding Customers}" AutoGenerateColumns="False" Height="550">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CLIENT NAME" Binding="{Binding Name}" Width="250"/>
                            <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*"/>
                            <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </DataTemplate>

            <!-- 7. HR MODULE (With Semantic Status Colors) -->
            <DataTemplate DataType="{x:Type vm:HRViewModel}">
                <StackPanel Margin="20">
                    <TextBlock Text="HR / Staff Directory" FontSize="26" FontWeight="Black" Foreground="White" Margin="0,0,0,25"/>
                    <DataGrid ItemsSource="{Binding Employees}" AutoGenerateColumns="False" Height="550">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="DEPARTMENT" Binding="{Binding Department}" Width="150"/>
                            <DataGridTextColumn Header="POSITION" Binding="{Binding Position}" Width="200"/>
                            <DataGridTemplateColumn Header="STATUS" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextStyle}" Margin="10,0"/></DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </DataTemplate>

            <!-- FINANCE MODULE (Colorful KPI Digits) -->
            <DataTemplate DataType="{x:Type vm:FinanceViewModel}">
                <StackPanel Margin="20">
                    <TextBlock Text="Financial Intelligence" FontSize="26" FontWeight="Black" Foreground="White" Margin="0,0,0,25"/>
                    <UniformGrid Columns="3">
                        <Border Background="#1E1E1E" Padding="25" Margin="5" CornerRadius="12" BorderThickness="0,0,0,4" BorderBrush="LimeGreen">
                            <StackPanel>
                                <TextBlock Text="ANNUAL REVENUE" Foreground="#888" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding AnnualRevenue}" FontSize="28" Foreground="White" FontWeight="Black" Margin="0,10"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1E1E1E" Padding="25" Margin="5" CornerRadius="12" BorderThickness="0,0,0,4" BorderBrush="{StaticResource PrimaryBrush}">
                            <StackPanel>
                                <TextBlock Text="PROFIT MARGIN" Foreground="#888" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ProfitMargin}" FontSize="28" Foreground="White" FontWeight="Black" Margin="0,10"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1E1E1E" Padding="25" Margin="5" CornerRadius="12" BorderThickness="0,0,0,4" BorderBrush="OrangeRed">
                            <StackPanel>
                                <TextBlock Text="Tax Liability" Foreground="#888" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TaxLiability}" FontSize="28" Foreground="White" FontWeight="Black" Margin="0,10"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </DataTemplate>

            <!-- SETTINGS MODULE -->
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <StackPanel Margin="20">
                    <TextBlock Text="System Configuration" FontSize="24" Foreground="White" Margin="0,0,0,20"/>
                    <Border Background="#1A1A1A" Padding="30" CornerRadius="15">
                        <StackPanel>
                            <Grid Margin="0,10">
                                <TextBlock Text="Application Version" Foreground="#888"/>
                                <TextBlock Text="{Binding SystemVersion}" Foreground="White" HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Background="#333"/>
                            <Grid Margin="0,10">
                                <TextBlock Text="Database Connectivity" Foreground="#888"/>
                                <TextBlock Text="{Binding DatabaseStatus}" Foreground="LimeGreen" HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Background="#333"/>
                            <Grid Margin="0,10">
                                <TextBlock Text="Global Branding" Foreground="#888"/>
                                <TextBlock Text="SHIGOSAG NEXUS" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>