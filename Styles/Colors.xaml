<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="PrimaryPink">#FF1493</Color>
    <Color x:Key="DarkBg">#0F0F0F</Color>
    <Color x:Key="SurfaceBg">#1A1A1A</Color>
    <Color x:Key="TextWhite">#FFFFFF</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryPink}"/>
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource DarkBg}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceBg}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextWhite}"/>
    
    <LinearGradientBrush x:Key="PinkGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1493" Offset="0"/>
        <GradientStop Color="#8B008B" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>