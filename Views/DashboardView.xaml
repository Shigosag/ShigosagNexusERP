<UserControl x:Class="ShigosagNexusERP.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1200">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="20">
            <!-- Header Section -->
            <TextBlock Text="Nexus Command Center" FontSize="32" FontWeight="Black" Foreground="White" Margin="5,0,0,30"/>

            <!-- HIGH-IMPACT TELEMETRY KPI CARDS -->
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,30">
                
                <!-- Aggregate Ledger (Rose Pink) -->
                <Border Background="#1A1418" Margin="8" Padding="20" CornerRadius="15" BorderThickness="1.5" BorderBrush="#FF1493">
                    <StackPanel>
                        <Path Data="{StaticResource IconSales}" Fill="#FF1493" Stretch="Uniform" Width="22" HorizontalAlignment="Left" Opacity="0.9"/>
                        <TextBlock Text="AGGREGATE LEDGER" Foreground="#888" FontSize="10" FontWeight="Bold" Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding AggregateLedger}" Foreground="White" FontSize="26" FontWeight="Black" Margin="0,5"/>
                        <TextBlock Text="TOTAL PORTFOLIO VALUE" Foreground="#FF1493" FontSize="9" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Inflow Cleared (Emerald Green) -->
                <Border Background="#141A16" Margin="8" Padding="20" CornerRadius="15" BorderThickness="1.5" BorderBrush="#2ECC71">
                    <StackPanel>
                        <Path Data="{StaticResource IconDashboard}" Fill="#2ECC71" Stretch="Uniform" Width="22" HorizontalAlignment="Left" Opacity="0.9"/>
                        <TextBlock Text="INFLOW CLEARED" Foreground="#888" FontSize="10" FontWeight="Bold" Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding InflowCleared}" Foreground="White" FontSize="26" FontWeight="Black" Margin="0,5"/>
                        <TextBlock Text="RECONCILED CAPITAL" Foreground="#2ECC71" FontSize="9" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Pipeline Bookings (Amber Yellow) -->
                <Border Background="#1A1914" Margin="8" Padding="20" CornerRadius="15" BorderThickness="1.5" BorderBrush="#F1C40F">
                    <StackPanel>
                        <Path Data="{StaticResource IconInventory}" Fill="#F1C40F" Stretch="Uniform" Width="22" HorizontalAlignment="Left" Opacity="0.9"/>
                        <TextBlock Text="PIPELINE BOOKINGS" Foreground="#888" FontSize="10" FontWeight="Bold" Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding PipelineBookings}" Foreground="White" FontSize="26" FontWeight="Black" Margin="0,5"/>
                        <TextBlock Text="EXPECTED BILLING" Foreground="#F1C40F" FontSize="9" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Capital Exposed (Rose Red) -->
                <Border Background="#1A1415" Margin="8" Padding="20" CornerRadius="15" BorderThickness="1.5" BorderBrush="#E91E63">
                    <StackPanel>
                        <Path Data="{StaticResource IconHR}" Fill="#E91E63" Stretch="Uniform" Width="22" HorizontalAlignment="Left" Opacity="0.9"/>
                        <TextBlock Text="CAPITAL EXPOSED" Foreground="#888" FontSize="10" FontWeight="Bold" Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding CapitalExposed}" Foreground="White" FontSize="26" FontWeight="Black" Margin="0,5"/>
                        <TextBlock Text="AT-RISK OVERDUE" Foreground="#E91E63" FontSize="9" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                
            </UniformGrid>

            <!-- ANALYTICS CHARTS SECTION: MODERNIZED WITH XY RULERS & SMOOTH CURVES -->
<Grid Margin="0,0,0,30">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.7*"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- REVENUE FLOW & CAPITAL OVERHEADS (SMOOTH AREA CHART) -->
    <Border Grid.Column="0" Background="#161616" Margin="8" Padding="30" CornerRadius="20">
        <StackPanel>
            <DockPanel LastChildFill="True" Margin="0,0,0,30">
                <TextBlock Text="Revenue Flow &amp; Overheads" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="DeepSkyBlue" Width="10" Height="10" CornerRadius="5" Margin="10,0,5,0"/>
                    <TextBlock Text="Inflow" Foreground="#666" FontSize="11"/>
                    <Border Background="#FF1493" Width="10" Height="10" CornerRadius="5" Margin="15,0,5,0"/>
                    <TextBlock Text="Outflow" Foreground="#666" FontSize="11"/>
                </StackPanel>
            </DockPanel>

            <Grid Height="275">
                <Grid.RowDefinitions>
                    <RowDefinition Height="250"/> <!-- Chart Area -->
                    <RowDefinition Height="Auto"/> <!-- Month Labels -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Y-Axis Labels -->
                    <ColumnDefinition Width="*"/>    <!-- Chart Area -->
                </Grid.ColumnDefinitions>

                <!-- Y-Axis Ruler -->
                <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Stretch" Margin="0,0,15,0">
                    <TextBlock Text="25k" Foreground="#444" FontSize="10" Height="62"/>
                    <TextBlock Text="15k" Foreground="#444" FontSize="10" Height="62"/>
                    <TextBlock Text="5k" Foreground="#444" FontSize="10" Height="62"/>
                    <TextBlock Text="0" Foreground="#444" FontSize="10" VerticalAlignment="Bottom"/>
                </StackPanel>

                <!-- Chart Canvas -->
                <Grid Grid.Row="0" Grid.Column="1">
                    <!-- XY Axis Lines -->
                    <Border BorderThickness="1,0,0,1" BorderBrush="#333" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                    
                    <!-- Smooth Area (Inflow) - Bezier Curve -->
                    <Path Stretch="Fill" Data="M 0,100 C 20,80 40,20 60,60 C 80,90 90,10 100,30 L 100,100 L 0,100 Z" Margin="1,0,0,1">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#4400BFFF" Offset="0"/>
                                <GradientStop Color="#0000BFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Path.Fill>
                    </Path>
                    
                    <!-- Smooth Line (Inflow) -->
                    <Path Stroke="DeepSkyBlue" StrokeThickness="1.5" Stretch="Fill" 
                          Data="M 0,100 C 20,80 40,20 60,60 C 80,90 90,10 100,30" Margin="1,0,0,1"/>

                    <!-- Smooth Line (Outflow) - Dashed -->
                    <Path Stroke="#FF1493" StrokeThickness="2" StrokeDashArray="3 2" Stretch="Fill" 
                          Data="M 0,95 C 30,85 50,95 70,50 C 85,30 100,60 100,60" Margin="1,0,0,1"/>
                </Grid>

                    <!-- X-Axis Month Labels -->
                    <UniformGrid Grid.Row="1" Grid.Column="1" Columns="12" Margin="0,10,0,0">
                        <TextBlock Text="Jan" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Feb" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Mar" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Apr" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="May" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Jun" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Jul" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Aug" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Sep" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Oct" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Nov" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Dec" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                    </UniformGrid>
            </Grid>
        </StackPanel>
    </Border>

    <!-- GROWTH INDEX DISTRIBUTION -->
    <Border Grid.Column="1" Background="#161616" Margin="8" Padding="30" CornerRadius="20">
        <StackPanel>
            <TextBlock Text="Growth Index Distribution" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,30"/>
            <Grid Height="250">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Y-Axis Ruler -->
                <StackPanel Grid.Column="0" VerticalAlignment="Stretch" Margin="0,0,15,0">
                    <TextBlock Text="100%" Foreground="#444" FontSize="10" Height="62"/>
                    <TextBlock Text="50%" Foreground="#444" FontSize="10" Height="62"/>
                    <TextBlock Text="25%" Foreground="#444" FontSize="10" Height="62"/>
                    <TextBlock Text="0%" Foreground="#444" FontSize="10" VerticalAlignment="Bottom"/>
                </StackPanel>

                <!-- Bar Area -->
                <Grid Grid.Column="1">
                    <!-- XY Axis Lines -->
                    <Border BorderThickness="1,0,0,1" BorderBrush="#333" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>

                    <!-- Bars (Starting from bottom 0) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="5,0,0,1">
                        <StackPanel VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="90" Width="32" Background="#FF1493" CornerRadius="6,6,0,0" Opacity="0.9"/>
        <TextBlock Text="Q1" Foreground="#555" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="160" Width="32" Background="#FF1493" CornerRadius="6,6,0,0" Opacity="0.9"/>
                            <TextBlock Text="Q2" Foreground="#555" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="110" Width="32" Background="#FF1493" CornerRadius="6,6,0,0" Opacity="0.9"/>
                            <TextBlock Text="Q3" Foreground="#555" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="210" Width="32" Background="#FF1493" CornerRadius="6,6,0,0" Opacity="0.9"/>
                            <TextBlock Text="Q4" Foreground="#555" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </StackPanel>
    </Border>
</Grid>

            <!-- TELEMETRY & SYSTEM ACTIVITY STREAM -->
            <Border Background="#161616" Margin="8,0,8,10" Padding="30" CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="Telemetry &amp; System Activity Stream" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{Binding RecentActivities}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1" BorderBrush="#222" Padding="0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Fill="{StaticResource PrimaryBrush}" Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#999" FontSize="13" FontFamily="Consolas"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>